APP_NAME="Digital Wallet"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Banco de Dados ──────────────────────────────────────────────────────────
# MySQL
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=digital_wallet
DB_USERNAME=root
DB_PASSWORD=

# PostgreSQL (alternativa)
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=digital_wallet
# DB_USERNAME=postgres
# DB_PASSWORD=

# ─── Cache / Session / Queue ─────────────────────────────────────────────────
BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ─── Sanctum ─────────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000

# ─── Swagger / OpenAPI ───────────────────────────────────────────────────────
L5_SWAGGER_GENERATE_ALWAYS=true
L5_SWAGGER_CONST_HOST=http://localhost:8000
L5_FORMAT_TO_USE_FOR_DOCS=json

# ─── Produção (Railway / Render) ─────────────────────────────────────────────
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://seu-dominio.up.railway.app
# L5_SWAGGER_CONST_HOST=https://seu-dominio.up.railway.app
